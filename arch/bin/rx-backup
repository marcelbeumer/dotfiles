#!/usr/bin/env bash
#
# rx-backup — restic backup for home and /etc
#
# CONFIGURATION
#   Required environment variables:
#     RESTIC_REPO          restic repository URL (e.g. sftp:user@host:/path/to/repo)
#     BACKUP_USER          local user whose home directory is backed up
#
#   Optional environment variables:
#     BACKUP_USER_EXCLUDE_FILE  path to a file with additional exclude paths, one per line
#                               lines starting with # and blank lines are ignored
#                               can live anywhere, e.g. /home/user/.config/rx-backup-excludes
#
# MANUAL RUN
#   Use rx-backup-as-user
#
# SYSTEMD SETUP (system unit — runs as root)
#
#   1. Create an environment file (chmod 600 so only root can read it):
#        cat > /etc/rx-backup.env <<EOF
#        RESTIC_REPO=sftp:user@host:/storage/repo
#        BACKUP_USER=alice
#        EOF
#        chmod 600 /etc/rx-backup.env
#
#   2. Create /etc/systemd/system/rx-backup.service:
#        [Unit]
#        Description=restic backup (home + etc)
#        After=network-online.target
#        Wants=network-online.target
#
#        [Service]
#        Type=oneshot
#        EnvironmentFile=/etc/rx-backup.env
#        ExecStart=/usr/local/bin/rx-backup
#
#   3. Create /etc/systemd/system/rx-backup.timer:
#        [Unit]
#        Description=run rx-backup daily
#
#        [Timer]
#        OnCalendar=daily
#        Persistent=true
#
#        [Install]
#        WantedBy=timers.target
#
#   4. Enable and start:
#        systemctl daemon-reload
#        systemctl enable --now rx-backup.timer

if [ "$EUID" -ne 0 ]; then
  echo "Please run as root: sudo $0"
  exit 1
fi

set -euo pipefail

repo="${RESTIC_REPO:?RESTIC_REPO is not set}"
backup_user="${BACKUP_USER:?BACKUP_USER is not set}"

exclude_args=()
if [[ -n "${BACKUP_USER_EXCLUDE_FILE:-}" ]]; then
  mapfile -t _excludes < "$BACKUP_USER_EXCLUDE_FILE"
  for _exc in "${_excludes[@]}"; do
    [[ "$_exc" =~ ^# ]] && continue
    [[ -z "$_exc" ]] && continue
    exclude_args+=(--exclude "$_exc")
  done
fi

pacman -Qqe > /home/$backup_user/pkglist.txt

restic -r "$repo" backup \
  /home/$backup_user \
  /etc \
  --exclude /home/$backup_user/.cache \
  --exclude /home/$backup_user/.local/share/Trash \
  ${exclude_args[@]+"${exclude_args[@]}"} \
  --compression auto

restic -r "$repo" forget \
  --keep-daily 7 \
  --keep-weekly 4 \
  --keep-monthly 6 \
  --prune

restic -r "$repo" snapshots
restic -r "$repo" stats
