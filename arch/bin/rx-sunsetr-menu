#!/usr/bin/env bash

EXIT_BACK=1
EXIT_ESC=2

preset=$(sunsetr status --json 2>/dev/null | jq -r '.active_preset' 2>/dev/null)
[[ "$preset" == "default" ]] && preset="Default"

case "$1" in
  --sub)
    items="← Back\nDefault\nDay\nReading\nWarm"
    ;;
  *)
    items="Default\nDay\nReading\nWarm"
    ;;
esac

lines=$(echo -e "$items" | wc -l)
choice=$(echo -e "$items" | rofi -dmenu -theme-str "listview { lines: $lines; }" -i -p "Sunsetr" -select "$preset")
[[ -z "$choice" ]] && exit $EXIT_ESC
[[ "$choice" == "← Back" ]] && exit $EXIT_BACK

case "$choice" in
  "Default")  sunsetr preset default ;;
  "Day")     sunsetr preset day ;;
  "Reading") sunsetr preset reading ;;
  "Warm")    sunsetr preset warm ;;
esac

sleep 1 # needs time to change state
