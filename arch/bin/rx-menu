#!/usr/bin/env bash

main_menu() {
  echo -e "Next wallpaper\nTheme\nInstall\nInstall AUR\nRemove\nUpdate\nUpdate AUR\nUpdate All\nLock\nSleep\nReboot\nShutdown" | rofi -dmenu -theme-str 'listview { lines: 12; }' -i -p "Menu"
}

theme_menu() {
  { echo "← Back"; rx-theme -l; } | rofi -dmenu -i -p "Theme" -select $(rx-theme)
}

while true; do
  choice=$(main_menu)
  [[ -z "$choice" ]] && exit 0

  case "$choice" in
    "Next wallpaper")
      rx-wallpaper-next
      ;;
    "Install")
      rx-launch-floating-terminal rx-pkg-install &
      break
      ;;
    "Install AUR")
      rx-launch-floating-terminal rx-pkg-aur-install &
      break
      ;;
    "Remove")
      rx-launch-floating-terminal rx-pkg-remove &
      break
      ;;
    "Update")
      rx-launch-floating-terminal rx-pkg-update &
      break
      ;;
    "Update AUR")
      rx-launch-floating-terminal rx-pkg-aur-update &
      break
      ;;
    "Update All")
      rx-launch-floating-terminal rx-pkg-all-update &
      break
      ;;
    "Lock")
      rx-lock
      break
      ;;
    "Sleep")
      systemctl suspend
      break
      ;;
    "Reboot")
      reboot
      ;;
    "Shutdown")
      shutdown now
      ;;
    "Theme")
      while true; do
        sub=$(theme_menu)
        [[ -z "$sub" || "$sub" == "← Back" ]] && break
        rx-theme $sub
      done
      ;;
  esac
done
